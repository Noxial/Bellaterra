# ── Admin Authentication ───────────────────────────────────────────────────
# Password required to access /admin — default: %bellaterra%26
ADMIN_PASSWORD=%bellaterra%26

# ── Site Access Protection ─────────────────────────────────────────────────
# Password required by visitors to enter the site (when protection is enabled)
# The admin can also change this at runtime via /admin/settings
SITE_PASSWORD=%bellaterra%26

# ── Nuxt / Nitro ──────────────────────────────────────────────────────────
# Set automatically by Vercel; set manually for other environments
# NITRO_PRESET=vercel
